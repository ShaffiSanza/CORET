# CORET Backend — Miljovariable
# Kopier denne filen til .env og fyll inn dine API-nokler:
#   cp .env.example .env

# SerpAPI — for produktsok (https://serpapi.com)
# Gratis: 100 sok/mnd
SERPAPI_KEY=

# UPCitemdb — for strekkode-oppslag (https://www.upcitemdb.com/wp/docs/main/development/api/)
# Trial-tier krever ingen nokkel (bare rate-limited)
UPCITEMDB_KEY=

# Photoroom — for bildeforbedring / Pro-funksjon (https://www.photoroom.com/api)
PHOTOROOM_API_KEY=

# --- Sikkerhet ---
# API-nokkel som iOS-appen sender med hver request (X-API-Key header)
# Generer en tilfeldig nokkel: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Hvis tom: auth er deaktivert (kun for development)
CORET_API_KEY=

# Maks requests per minutt per IP (standard: 30)
RATE_LIMIT_PER_MINUTE=30

# CORS — hvilke domener som kan kalle API-et
# Kommaseparert liste. iOS-apper trenger ikke CORS, men nettlesere gjor det.
ALLOWED_ORIGINS=https://coret-production.up.railway.app

# Miljo — "development" eller "production"
ENVIRONMENT=development
